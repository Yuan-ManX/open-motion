{
  "name": "@openmotion/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "openmotion-mcp": "./bin/mcp-stdio.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "build": "tsc -p tsconfig.json && node scripts/postbuild.mjs",
    "typecheck": "tsc --noEmit",
    "mcp:stdio": "tsx bin/mcp-stdio.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "@openmotion/shared": "file:./src/shared",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.2.0",
    "puppeteer-core": "^23.11.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
